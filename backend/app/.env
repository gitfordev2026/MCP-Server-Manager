 
 
#------------frontend------------
# Backend API URL for frontend (required for Next.js)
NEXT_PUBLIC_BE_API_URL=http://127.0.0.1:8099
 
#------------keycloak------------
# Toggle auth
AUTH_ENABLED=true
 

MCP_USE_ANONYMIZED_TELEMETRY=false

# Keycloak server + realm
# KEYCLOAK_SERVER_URL=http://localhost:8080
# KEYCLOAK_REALM=mcp-realm
 
# # Client used by your frontend/backend tokens
# KEYCLOAK_CLIENT_ID=mcp-dashboard-client

KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=mcp-realm
KEYCLOAK_CLIENT_ID=mcp_server

 
# Public clients don't get client_id in the aud claim â€” disable for now.
# To re-enable, add an "audience" protocol mapper in Keycloak for mcp_server.
KEYCLOAK_VERIFY_AUD=false


 
 
 
#------------database------------
 
# PostgreSQL (primary) - Docker at localhost:5432
 
DATABASE_URL=postgresql://postgres:postgres@11.0.25.133:5432/mcp_manager-7
#  DATABASE_URL=postgresql://postgres:admin@127.0.0.1:5432/mcp_manager-5
 
# Set to true to fallback to SQLite if PostgreSQL is unavailable
 
DB_FALLBACK_SQLITE=false

#------------feature-flags------------
RBAC_ENFORCED=true
DEFAULT_POLICY_MODE=allow
LIVE_MCP_REGISTRY_ONLY=true
LIVE_MONITOR_ENABLED=true
LLM_CHAT_ENABLED=true
PLAYGROUND_ENABLED=true
REDIS_URL=redis://localhost:6379/0
HEALTH_CHECK_INTERVAL_SEC=5
HEALTH_CHECK_TIMEOUT_SEC=5

#------------keycloak service-to-service (ADM domain)------------
ADM_KEYCLOAK_SERVER_URL=http://localhost:8080/realms/mcp-realm/protocol/openid-connect/token
ADM_KEYCLOAK_REALM=mcp-realm
ADM_KEYCLOAK_CLIENT_ID=mcp_secure
ADM_KEYCLOAK_CLIENT_SECRET=74OxZuFHRoHZNWON8yOSHDRnspzlJXwH

# OPS domain (same realm, same client â€” mirror ADM since all apps are in IAF)
OPS_KEYCLOAK_SERVER_URL=http://localhost:8080/realms/mcp-realm/protocol/openid-connect/token
OPS_KEYCLOAK_REALM=mcp-realm
OPS_KEYCLOAK_CLIENT_ID=mcp_secure
OPS_KEYCLOAK_CLIENT_SECRET=74OxZuFHRoHZNWON8yOSHDRnspzlJXwH
